{
  "name": "basicspa",
  "version": "2.0.0",
  "description": "An SPA using the OIDC Client security library and a full OAuth lifecycle",
  "author": "Gary Archer",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "lint": "eslint .",
    "start": "rm -rf dist && tsx tools/start.ts",
    "build": "rm -rf dist && NODE_OPTIONS='--import tsx' rollup --config build/rollup.config.ts"
  },
  "dependencies": {
    "mustache": "^4.2.0",
    "oidc-client-ts": "^3.5.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mustache": "^4.2.5",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "workspaces": [
    "build",
    "tools"
  ]
}
